# Paths are interpreted inside the Linux container, not on the Windows host.
# The temporary repo clone is cleaned at the start of the next run.
BLUEPOSTS_REPO_ROOT=/tmp/blueposts-repo
BLUEPOSTS_REPO_URL=https://github.com/WSakhana/BluePosts.git
# Optional GitHub token used to authenticate clone/fetch/pull/push over HTTPS
# without embedding credentials in BLUEPOSTS_REPO_URL.
# BLUEPOSTS_GITHUB_TOKEN=
# Local Google Drive export is preserved between runs and synced incrementally.
BLUEPOSTS_SOURCE_PATH=/tmp/blueposts-source
BLUEPOSTS_DRIVE_FOLDER_ID=153osz5cXU3C0Ju07AJ0YArt2LQbbsjny
# Mount the JSON from the host to this path inside the container.
# Example for Docker Desktop on Windows:
# -v D:/VM/n8n-gdrive-493909-c9fa3e30cfcf.json:/run/secrets/google-service-account.json:ro
# Optional when the secret is mounted at /run/secrets/google-service-account.json.
# BLUEPOSTS_GOOGLE_CREDENTIALS=/run/secrets/google-service-account.json
BLUEPOSTS_GIT_REMOTE=origin
BLUEPOSTS_GIT_BRANCH=main
# Automatically increments the next tag if BLUEPOSTS_VERSION is not forced.
# patch: 1.0.2 -> 1.0.3 -> ... -> 1.0.9 -> 1.1.0
BLUEPOSTS_VERSION_BUMP=patch
