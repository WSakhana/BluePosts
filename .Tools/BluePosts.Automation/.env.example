# Chemins interpretes dans le conteneur Linux, pas sur l'hote Windows.
# Repo clone temporaire nettoye au debut du lancement suivant.
BLUEPOSTS_REPO_ROOT=/tmp/blueposts-repo
BLUEPOSTS_REPO_URL=https://github.com/WSakhana/BluePosts.git
# Export Google Drive temporaire nettoye au debut du lancement suivant.
BLUEPOSTS_SOURCE_PATH=/tmp/blueposts-source
BLUEPOSTS_DRIVE_FOLDER_ID=153osz5cXU3C0Ju07AJ0YArt2LQbbsjny
# Montez le JSON depuis l'hote vers ce chemin dans le conteneur.
# Exemple Docker Desktop Windows:
# -v D:/VM/n8n-gdrive-493909-c9fa3e30cfcf.json:/run/secrets/google-service-account.json:ro
BLUEPOSTS_GOOGLE_CREDENTIALS=/run/secrets/google-service-account.json
BLUEPOSTS_GIT_REMOTE=origin
BLUEPOSTS_GIT_BRANCH=main
# Incrementation auto du prochain tag si BLUEPOSTS_VERSION n'est pas forcee.
# patch: 1.0.2 -> 1.0.3 -> ... -> 1.0.9 -> 1.1.0
BLUEPOSTS_VERSION_BUMP=patch
